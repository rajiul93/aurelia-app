{
  "expo": {
    "name": "aurelia-app",
    "slug": "aurelia-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "aureliaapp",
    "userInterfaceStyle": "automatic",
    "ios": {
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Aurelia uses your location to guide you along your downloaded walking tour route while the app is open."
      },
      "bundleIdentifier": "com.rajiul.aureliaapp"
    },
    "android": {
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png"
      },
      "predictiveBackGestureEnabled": false,
      "softwareKeyboardLayoutMode": "resize",
      "package": "com.rajiul.aureliaapp"
    },
    "plugins": [
      "expo-router",
      "expo-dev-client",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Aurelia uses your location to guide you along your downloaded walking tour route while the app is open."
        }
      ],
      "@maplibre/maplibre-react-native",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0c0a09",
          "image": "./assets/images/splash-icon.png",
          "resizeMode": "cover"
        }
      ],
      "expo-audio",
      "expo-video",
      [
        "@stripe/stripe-react-native",
        {
          "enableGooglePay": false
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "2d8da654-cf10-4f38-8d23-48475a4cd614"
      }
    }
  }
}
