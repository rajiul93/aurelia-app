# Mobile API (admin-and-server-aurelia /api/v1/app)
# On a physical device, localhost is auto-rewritten to your Mac's LAN IP
# (from Expo Metro host). Keep admin server running: pnpm run dev
EXPO_PUBLIC_API_BASE_URL="http://localhost:3000/api/v1/app"
# EXPO_PUBLIC_API_BASE_URL="https://aurelia-admin-server.vercel.app/api/v1/app"

# Must match admin MOBILE_API_KEY (.env locally, Vercel env in production)
EXPO_PUBLIC_MOBILE_API_KEY="your-app-key"
EXPO_PUBLIC_API_VERSION="1"

# Stripe publishable key (safe to expose client-side — https://dashboard.stripe.com/apikeys)
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
